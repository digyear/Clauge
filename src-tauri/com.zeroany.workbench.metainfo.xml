<component type="desktop-application">
  <id>com.zeroany.workbench</id>
  <name>ZeroAny Workbench</name>
  <summary>Zero, one, any workspace</summary>
  <description>
    <p>
      ZeroAny Workbench is an all-in-one developer desktop app. It brings your entire development
      workflow into one place — so you can focus on building instead of switching between tools.
    </p>
    <p>
      Designed to grow with you, ZeroAny Workbench brings agents, developer tools, and project
      workflows together in a single unified interface.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Claude AI agent with context-aware sessions</li>
      <li>REST API client with collections and environments</li>
      <li>SQL and NoSQL database explorer and query runner</li>
      <li>SSH terminal with profile management</li>
      <li>Remote file explorer (SFTP, FTP, S3, Azure Blob)</li>
    </ul>
  </description>

  <launchable type="desktop-id">ZeroAny Workbench.desktop</launchable>

